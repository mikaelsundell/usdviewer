/* Top-level widgets */
QMainWindow,
QDialog
{
    font-size: $defaultsize;
    background-color: $base;
}

QMainWindow::separator {
    background: $base;
    width: 6px;
}

QCheckBox {
    color: $text;
    background-color: $base;
    font-size: $defaultsize;
    spacing: 8px;
    padding-right: 10px;
}

QCheckBox::indicator {
    width: 18px;
    height: 18px;
    background-color: $basealt;
    border: 1px solid $borderalt;
}

QCheckBox::indicator:checked {
    image: url(":/icons/resources/Checked.png");
}

QCheckBox::indicator:indeterminate {
    image: url(":/icons/resources/PartiallyChecked.png");
}

QComboBox {
    color: $text;
    font-size: $defaultsize;
    background-color: $basealt;
    padding-left: 10px;
    padding-right: 10px;
    padding-bottom: 2px;
    border-radius: 0px;
    margin-top: 4px;
    outline: none;
    border: 1px solid $border;
}

QComboBox:disabled {
    color: $textdisabled;
}

QComboBox::down-arrow {
    image: url(":/icons/resources/Dropdown.png");
    width: 12px;
    height: 12px;
}

QComboBox::drop-down {
    subcontrol-origin: padding;
    subcontrol-position: top right;
    width: 16px;
    right: 4px;
    border: 0px;
}

QComboBox::item {
    color: $text;
    height: 10px;
    background-color: $basealt;
    border: 8px solid transparent;
}

QComboBox::item:selected {
    background: $highlight;
}

QDockWidget {
    background: $dock;
}

QWidget[DockWidget="true"] {
    background-color: $dock;
}

QLabel
{
    font-size: $defaultsize;
    color: $text;
}

QLineEdit
{
    color: $text;
    font-size: $defaultsize;
    background-color: $base;
    height: 20px;  
    min-width: 50px;      
    border: 1px solid $borderalt;
    border-radius: 0px;        
    padding: 2px;
    padding-left: 5px;
    padding-right: 5px;
}

QMenu {
    background-color: $base;
    border: 1px solid $borderalt;
    padding: 4px;
}

QMenu::item {
    color: $text;
    background-color: transparent;
    padding: 4px 20px 4px 20px;
    font-size: $defaultsize;
}

QMenu::item:disabled {
    color: $textdisabled;
}

QMenu::item:selected {
    background-color: $highlight;
}

QMenu::separator {
    height: 1px;
    margin: 4px 4px;
    background-color: $borderalt;
}

QMenu::indicator {
    width: 16px;
    height: 16px;
}

QMenu::indicator:checked {
    image: url(":/icons/resources/Checked.png");
}

QMenu::right-arrow {
    image: url(":/icons/resources/Left.png");
}

QMenu::left-arrow {
    image: url(":/icons/resources/Right.png");
}

QProgressBar {
    min-height: 10px;
    max-height: 10px; 
    border-radius: 4px;
    background-color: $base;
}

QProgressBar::chunk {
    border-radius: 4px;
    background-color: $highlight;
}

QPushButton
{
    color: $text;
    font-size: $defaultsize;
    background-color: 
    QLinearGradient( 
        x1: 0, y1: 0, x2: 0, y2: 1, 
        stop: 0 $button,
        stop: 1.0 $buttonalt
    );
    height: 20px;  
    min-width: 50px;      
    border: 1px solid $borderalt;
    border-radius: 0px;        
    padding: 2px;
    padding-left: 5px;
    padding-right: 5px;
}

QPushButton:default
{
    font-weight: bold;
}

QPushButton:disabled
{
    color: $textdisabled;
}

QPushButton:pressed
{
    background-color: 
    QLinearGradient( 
        x1: 0, y1: 0, x2: 0, y2: 1, 
        stop: 0 $button.lightness(120),
        stop: 1.0 $buttonalt.lightness(120)
    );
}

QSplitter::handle {
    background-color: $dock;
    height: 5px;
}

QStatusBar {
    font-size: $defaultsize;
    color: $text;
    background: $dock;
}

QTextBrowser
{
    font-size: $defaultsize;
    color: $text;
    background-color: $base;
    selection-background-color: $highlight;
    alternate-background-color: $base;
}

QTreeView
{
    font-size: $defaultsize;
    color: $text;
    outline: none;
    border: 1px solid $borderalt;
    background-color: $base;
    selection-background-color: $highlight;
    alternate-background-color: $basealt;
}

QTreeView QHeaderView:section
{
    font-size: $defaultsize;
    color: $text;
    background-color: $dockalt;
    border: none;
    padding: 4px 6px;
}

QTreeView::item {
    height: 32px;
    font-size: $defaultsize;
    color: $text;
    border: none;
}