/* Top-level widgets */
QMainWindow,
QDialog
{
    font-size: $font.size.medium;
    background-color: $color.base;
}

QMainWindow::separator {
    background: $color.base;
    width: 6px;
}

QCheckBox {
    color: $color.text;
    background-color: $color.base;
    font-size: $font.size.medium;
    spacing: 8px;
    padding-right: 10px;
}

QCheckBox::indicator {
    width: 18px;
    height: 18px;
    background-color: $color.basealt;
    border: 1px solid $color.borderalt;
}

QCheckBox::indicator:checked {
    image: url("$icon.checked");
}

QCheckBox::indicator:indeterminate {
    image: url("$icon.partiallychecked");
}

QComboBox {
    color: $color.text;
    font-size: $font.size.medium;
    background-color: $color.basealt;
    padding-left: 10px;
    padding-right: 10px;
    padding-bottom: 2px;
    border-radius: 0px;
    margin-top: 4px;
    outline: none;
    border: 1px solid $color.border;
}

QComboBox:disabled {
    color: $color.text.disabled;
}

QComboBox::down-arrow {
    image: url("$icon.dropdown");
    width: 12px;
    height: 12px;
}

QComboBox::drop-down {
    subcontrol-origin: padding;
    subcontrol-position: top right;
    width: 16px;
    right: 4px;
    border: 0px;
}

QComboBox::item {
    color: $color.text;
    height: 10px;
    background-color: $color.basealt;
    border: 8px solid transparent;
}

QComboBox::item:selected {
    background: $color.highlight;
}

QDockWidget {
    background: $color.dock;
}

QFrame {
    border: 1px solid $color.border;
}

QWidget[DockWidget="true"] {
    background-color: $color.dock;
}

QLabel
{
    font-size: $font.size.medium;
    color: $color.text;
    border: 0px;
}

QLineEdit
{
    color: $color.text;
    font-size: $font.size.medium;
    background-color: $color.base;
    selection-background-color: $color.highlight;
    height: 20px;  
    min-width: 50px;      
    border: 1px solid $color.borderalt;
    border-radius: 0px;        
    padding: 2px;
    padding-left: 5px;
    padding-right: 5px;
}

QMenu {
    background-color: $color.basealt;
    border: 1px solid $color.borderalt;
    padding: 4px;
}

QMenu::item {
    color: $color.text;
    background-color: transparent;
    padding: 4px 20px 4px 20px;
    font-size: $font.size.medium;
}

QMenu::item:disabled {
    color: $color.text.disabled;
}

QMenu::item:selected {
    background-color: $color.highlight;
}

QMenu::separator {
    height: 1px;
    margin: 4px 4px;
    background-color: $color.borderalt;
}

QMenu::indicator {
    width: 16px;
    height: 16px;
    image: url("$icon.checked");
}

QMenu::right-arrow {
    width: 16px;
    height: 16px;
    image: url("$icon.left");
}

QMenu::left-arrow {
    width: 16px;
    height: 16px;
    image: url("$icon.right");
}

QProgressBar {
    min-height: 10px;
    max-height: 10px; 
    border-radius: 4px;
    background-color: $color.base;
}

QPlainTextEdit
{
    font-family: "Menlo", "Consolas", "Courier New", monospace;
    font-size: 10px;
    color: $color.text;
    background-color: $color.base;
    selection-background-color: $color.highlight;
    selection-color: $color.text;
    border: 1px solid $color.borderalt;
    outline: none;
    padding: 6px;
}

QPlainTextEdit:disabled
{
    color: $color.text.disabled;
    background-color: $color.basealt;
    selection-background-color: $color.basealt;
    selection-color: $color.text.disabled;
}

QProgressBar::chunk {
    border-radius: 4px;
    background-color: $color.highlight;
}

QPushButton
{
    color: $color.text;
    font-size: $font.size.medium;
    background-color: 
    qlineargradient( 
        x1: 0, y1: 0, x2: 0, y2: 1, 
        stop: 0 $color.button,
        stop: 1.0 $color.buttonalt
    );
    height: 20px;  
    min-width: 50px;      
    border: 1px solid $color.borderalt;
    border-radius: 0px;        
    padding: 2px;
    padding-left: 5px;
    padding-right: 5px;
}

QPushButton:default
{
    font-weight: bold;
}

QPushButton:disabled
{
    color: $color.text.disabled;
}

QPushButton:pressed
{
    background-color: 
    qlineargradient( 
        x1: 0, y1: 0, x2: 0, y2: 1, 
        stop: 0 $color.button.lightness(120),
        stop: 1.0 $color.buttonalt.lightness(120)
    );
}

QScrollBar:horizontal {
    background: $color.base;
    height: 16px;
    margin: 0;
    border: none;
}

QScrollBar::handle:horizontal {
    background: $color.handle;
    min-width: 40px;
    border-radius: 4px;
    margin: 4px 4px;
}

QScrollBar::handle:horizontal:hover {
    background: $color.handle;
}

QScrollBar::add-line:horizontal,
QScrollBar::sub-line:horizontal {
    background: none;
    width: 0;
}

QScrollBar::left-arrow:horizontal,
QScrollBar::right-arrow:horizontal {
    background: none;
    width: 0;
    height: 0;
}

QScrollBar::add-page:horizontal,
QScrollBar::sub-page:horizontal {
    background: none;
}

QScrollBar:vertical {
    background: $color.base;
    width: 16px;
    margin: 0;
    border: none;
}

QScrollBar::handle:vertical {
    background: $color.handle;
    min-width: 20px;
    border-radius: 4px;
    margin: 4px 4px;
}

QScrollBar::handle:vertical:hover {
    background:$color.handle;
}

QScrollBar::add-line:vertical,
QScrollBar::sub-line:vertical {
    background: none;
    height: 0;
}

QScrollBar::up-arrow:vertical,
QScrollBar::down-arrow:vertical {
    background: none;
    width: 0;
    height: 0;
}

QScrollBar::add-page:vertical,
QScrollBar::sub-page:vertical {
    background: none;
}

QAbstractScrollArea::corner { 
    background: $color.base;
}

QSplitter::handle {
    background-color: $color.dock;
    height: 5px;
}

QStatusBar {
    font-size: $font.size.medium;
    color: $color.text;
    background: $color.dock;
}




QTabWidget::pane
{
    background-color: $color.base;
    border-left: 1px solid $color.borderalt;
    border-right: 1px solid $color.borderalt;
    border-bottom: 1px solid $color.borderalt;
    border-top: 0px;
    top: 0px;
}

QTabWidget::tab-bar
{
    alignment: left;
}

QTabBar
{
    background: transparent;
}

QTabBar::tab
{
    font-size: $font.size.medium;
    color: $color.text;
    background-color: $color.basealt;
    border-top: 1px solid $color.borderalt;
    border-left: 1px solid $color.borderalt;
    border-right: 1px solid $color.borderalt;
    border-bottom: 1px solid $color.borderalt;
    padding: 4px 8px;
    margin: 0px;
    margin-right: -1px;
    min-width: 80px;
}

QTabBar::tab:selected
{
    color: $color.text;
    background-color: $color.base;
    border-bottom-color: $color.base;
}

QTabBar::tab:!selected
{
    color: $color.text;
    background-color: $color.basealt;
}

QTabBar::tab:hover:!selected
{
    background-color: $color.basealt;
}





QTextBrowser
{
    font-size: $font.size.medium;
    color: $color.text;
    background-color: $color.base;
    selection-background-color: $color.highlight;
    alternate-background-color: $color.base;
}

QToolButton
{
    color: $color.text;
    font-size: $font.size.medium;
    background-color: 
    qlineargradient( 
        x1: 0, y1: 0, x2: 0, y2: 1, 
        stop: 0 $color.button,
        stop: 1.0 $color.buttonalt
    );
    border: 1px solid $color.borderalt;
    border-radius: 0px;        
    padding: 2px;
    padding-left: 5px;
    padding-right: 5px;
}

QToolButton:default
{
    font-weight: bold;
}

QToolButton:disabled
{
    color: $color.text.disabled;
}

QToolButton:checked
{
    background-color: 
    qlineargradient( 
        x1: 0, y1: 0, x2: 0, y2: 1, 
        stop: 0 $color.button.lightness(160),
        stop: 1.0 $color.buttonalt.lightness(160)
    );
}

QToolButton:pressed
{
    background-color: 
    qlineargradient( 
        x1: 0, y1: 0, x2: 0, y2: 1, 
        stop: 0 $color.button.lightness(160),
        stop: 1.0 $color.buttonalt.lightness(160)
    );
}

QSlider {
    background: transparent;
}

QSlider::groove:horizontal {
    height: 4px;
    border-radius: 4px;
    background: $color.base;
}

QSlider::handle:horizontal {
    width: 8px;
    background: $color.handle;
    border-radius: 4px;
    margin: -5px 0;
}

QSplitter
{
    border: 0px;
}

QTreeView
{
    font-size: $font.size.medium;
    color: $color.text;
    outline: none;
    border: 1px solid $color.borderalt;
    background-color: $color.base;
    selection-background-color: $color.highlight;
    alternate-background-color: $color.basealt;
}

QTreeView QHeaderView:section
{
    font-size: $font.size.medium;
    color: $color.text;
    background-color: $color.base;
    border: none;
    padding: 4px 6px;
}

QTreeView::item {
    height: 32px;
    font-size: $font.size.medium;
    color: $color.text;
    selection-background-color: $color.highlight;
}

QTreeView::branch:open:has-children {
    image: url("$icon.branchopen");
}

QTreeView::branch:closed:has-children {
    image: url("$icon.branchclosed");
}
